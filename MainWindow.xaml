<Window x:Class="NetScan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetScan — Network Inventory"
        Height="760" Width="1150"
        MinHeight="560" MinWidth="850"
        Background="#F1F5F9"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ── Buttons ── -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>

        <Style x:Key="BtnGray" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#16A34A"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style x:Key="TBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ── Column header ── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ── DataGrid cell ── -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid row ── -->
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="42"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header     -->
            <RowDefinition Height="Auto"/>  <!-- toolbar    -->
            <RowDefinition Height="Auto"/>  <!-- summary    -->
            <RowDefinition Height="*"/>     <!-- grid       -->
            <RowDefinition Height="Auto"/>  <!-- detail     -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ════════ HEADER ════════ -->
        <Border Grid.Row="0" Background="#1E3A5F" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬡" FontSize="26" Foreground="#3B82F6"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="NetScan" FontSize="20" FontWeight="Bold"
                                   Foreground="White" LineHeight="22"/>
                        <TextBlock Text="Network Inventory Tool" FontSize="11"
                                   Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#162D4A" CornerRadius="8"
                        Padding="14,8" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖥  " FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="NetworkInfoText"
                                   Text="Detecting local network…"
                                   FontSize="12" Foreground="#94A3B8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ════════ TOOLBAR ════════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- IP range -->
                <TextBlock Text="Subnet:" VerticalAlignment="Center"
                           FontSize="13" Foreground="#64748B" Margin="0,0,8,0"/>
                <TextBox x:Name="IpBaseBox" Width="130" Style="{StaticResource TBox}"
                         ToolTip="First three octets, e.g. 192.168.1"/>
                <TextBlock Text="." VerticalAlignment="Center" FontSize="16"
                           Margin="4,0" FontWeight="Bold"/>

                <!-- Range x–y -->
                <TextBox x:Name="StartRangeBox" Width="46" Style="{StaticResource TBox}"
                         TextAlignment="Center" ToolTip="Start host (1–254)"/>
                <TextBlock Text="–" VerticalAlignment="Center" Margin="4,0" FontSize="13"/>
                <TextBox x:Name="EndRangeBox" Width="46" Style="{StaticResource TBox}"
                         TextAlignment="Center" ToolTip="End host (1–254)"/>

                <!-- Buttons -->
                <Button x:Name="ScanButton" Content="▶  Scan Network"
                        Style="{StaticResource Btn}" Margin="12,0,0,0"
                        Click="ScanButton_Click"/>
                <Button x:Name="CancelButton" Content="◼  Stop"
                        Style="{StaticResource BtnRed}" Margin="8,0,0,0"
                        IsEnabled="False" Click="CancelButton_Click"/>

                <!-- Progress -->
                <StackPanel Margin="16,0" Width="220" VerticalAlignment="Center">
                    <ProgressBar x:Name="ScanProgressBar"
                                 Height="5" BorderThickness="0"
                                 Background="#E2E8F0" Foreground="#2563EB"
                                 Maximum="100" Value="0"/>
                    <TextBlock x:Name="ProgressText" FontSize="11"
                               Foreground="#64748B" Margin="0,3,0,0" Text=" "/>
                </StackPanel>

                <Separator Style="{x:Null}" Width="1" Background="#E2E8F0"
                           Height="28" Margin="0,0,8,0"/>

                <!-- Export -->
                <Button x:Name="ExportCsvBtn" Content="⬇  CSV"
                        Style="{StaticResource BtnGray}" IsEnabled="False"
                        Click="ExportCsvBtn_Click" ToolTip="Export to CSV"/>
                <Button x:Name="ExportJsonBtn" Content="⬇  JSON"
                        Style="{StaticResource BtnGray}" Margin="6,0,0,0"
                        IsEnabled="False" Click="ExportJsonBtn_Click"
                        ToolTip="Export to JSON"/>

            </StackPanel>
        </Border>

        <!-- ════════ SUMMARY BAR ════════ -->
        <Border Grid.Row="2" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="DeviceCountText"
                           Text="No scan performed yet."
                           FontSize="12" Foreground="#64748B"/>
            </StackPanel>
        </Border>

        <!-- ════════ DEVICE GRID ════════ -->
        <DataGrid Grid.Row="3"
                  x:Name="DevicesGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserReorderColumns="True" CanUserResizeColumns="True"
                  CanUserSortColumns="True" IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#F1F5F9"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFBFC"
                  BorderThickness="0"
                  FontSize="13"
                  VirtualizingPanel.IsVirtualizing="True"
                  SelectionChanged="DevicesGrid_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="IP Address"  Binding="{Binding IpAddress}"   Width="130" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Hostname"    Binding="{Binding Hostname}"     Width="210"/>
                <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}"   Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Vendor"      Binding="{Binding Vendor}"       Width="170"/>
                <DataGridTextColumn Header="Ping (ms)"   Binding="{Binding ResponseTimeMs}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#16A34A"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Open Ports"  Binding="{Binding OpenPortsDisplay}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#7C3AED"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <!-- Right-click context menu -->
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="🔍  Scan Ports on Selected" Click="CtxScanPorts_Click"/>
                    <MenuItem Header="📋  Copy IP" Click="CtxCopyIp_Click"/>
                    <MenuItem Header="📋  Copy MAC" Click="CtxCopyMac_Click"/>
                    <Separator/>
                    <MenuItem Header="🔄  Re-ping" Click="CtxReping_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- ════════ DETAIL PANEL ════════ -->
        <Border Grid.Row="4" x:Name="DetailPanel"
                Background="White" BorderBrush="#E2E8F0"
                BorderThickness="0,2,0,0" Padding="16,12"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- IP -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="IP ADDRESS" FontSize="10" Foreground="#94A3B8"
                               FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBlock x:Name="DetailIp" FontSize="16" FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>

                <!-- Hostname -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="HOSTNAME" FontSize="10" Foreground="#94A3B8"
                               FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBlock x:Name="DetailHostname" FontSize="13"
                               Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- MAC / Vendor -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="MAC / VENDOR" FontSize="10" Foreground="#94A3B8"
                               FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBlock x:Name="DetailMac" FontSize="12"
                               FontFamily="Consolas, Courier New" Foreground="#0F172A"/>
                    <TextBlock x:Name="DetailVendor" FontSize="11"
                               Foreground="#64748B" Margin="0,1,0,0"/>
                </StackPanel>

                <!-- Ports -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="OPEN PORTS" FontSize="10" Foreground="#94A3B8"
                               FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBlock x:Name="DetailPorts" FontSize="12" Foreground="#7C3AED"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="4" Orientation="Vertical"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="ScanPortsBtn" Content="🔍  Scan Ports"
                            Style="{StaticResource Btn}" Margin="0,0,0,6"
                            Click="ScanPortsBtn_Click"/>
                    <Button x:Name="QuickScanPortsBtn" Content="⚡  Quick Scan"
                            Style="{StaticResource BtnGreen}"
                            Click="QuickScanPortsBtn_Click"
                            ToolTip="Scan only most common 10 ports (faster)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════ STATUS BAR ════════ -->
        <Border Grid.Row="5" Background="#1E3A5F" Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready — click Scan Network to start."
                           FontSize="11" Foreground="#94A3B8"/>
                <TextBlock Grid.Column="1" Text="NetScan v1.0"
                           FontSize="10" Foreground="#475569"/>
            </Grid>
        </Border>
    </Grid>
</Window>
